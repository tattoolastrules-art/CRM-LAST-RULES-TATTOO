# Copia este archivo como .env.local y completa tu llave (NO lo subas a git)

# Llave de Claude (Anthropic) — la pones tú. https://console.anthropic.com
ANTHROPIC_API_KEY=

# (Opcional) Modelo del agente Lana. Por defecto Haiku 4.5 (rápido/económico).
# Más calidad: claude-sonnet-4-6  ·  máxima: claude-opus-4-8
LANA_MODEL=claude-haiku-4-5

# --- Google Calendar (Agenda de Los Maestros) ---
# Crea credenciales OAuth en Google Cloud Console. Guía paso a paso:
# docs/google-calendar-setup.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URL de retorno autorizada. En local déjala así; en producción cámbiala
# por https://TU-DOMINIO/api/google/callback (y agrégala en Google Cloud).
GOOGLE_REDIRECT_URI=http://localhost:3030/api/google/callback

# --- Base de datos Neon (opcional) ---
# Si la dejas vacía, el sistema usa archivos JSON en /data (funciona igual).
# Si pones la URL de Neon, el contenido y los usuarios se guardan en Postgres.
# Guía: docs/neon-setup.md
DATABASE_URL=

# Secreto para firmar la sesión de login. En local se autogenera solo;
# en producción (Vercel) pon una cadena larga aleatoria fija aquí.
AUTH_SECRET=

# --- Meta (WhatsApp / Instagram / Messenger) ---
# Token de verificación del webhook (el mismo que pongas en Meta).
META_VERIFY_TOKEN=
# (Opcional) App Secret de Meta, para validar la firma de los eventos.
META_APP_SECRET=
# Para ENVIAR mensajes por WhatsApp Cloud API:
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=1167992226400931
