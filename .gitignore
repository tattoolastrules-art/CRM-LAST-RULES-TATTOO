# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# secretos y datos locales (NO subir)
/.cpanel.env
/.meta.tmp
/data/

# espejo del sitio en vivo y backups (no son parte del OS)
/site/
/site-backup-*

# media de trabajo y herramientas locales (NO subir al repo)
/videos-input/
/media-out/
/tools/

# mantener el ejemplo de variables de entorno
!.env.example

/.vapid.tmp
